          3,
          4,
          5,
          6
        ]
      },
      {
        "call": "flatten([])",
        "expect": []
      },
      {
        "call": "flatten([[1],[2],[3]])",
        "expect": [
          1,
          2,
          3
        ]
      }
    ]
  }
}