{
  "id": "py-flatten",
  "type": "python-kata",
  "track": "progression",
  "title": "Flatten a nested list",
  "xp": 25,
  "prerequisites": [
    "py-two-sum"
  ],
  "review_interval_days": null,
  "prompt": "Write flatten(nested), a list of lists, returning a single flat list preserving order.",
  "starter_code": "def flatten(nested):\n    pass\n",
  "verification": {
    "runner": "python-test",
    "tests": [
      {
        "call": "flatten([[1,2],[3],[],[4,5,6]])",
        "expect": [
          1,
          2,
          3,
          4,
          5,
          6
        ]
      },
      {
        "call": "flatten([])",
        "expect": []
      },
      {
        "call": "flatten([[1],[2],[3]])",
        "expect": [
          1,
          2,
          3
        ]
      }
    ]
  },
  "details": {
    "restate": "You get a list whose items are themselves lists. Give back one single flat list with all the inner items, keeping their order.",
    "io": [
      {
        "call": "flatten([[1, 2], [3], [], [4, 5, 6]])",
        "returns": "[1, 2, 3, 4, 5, 6]",
        "because": "the inner lists are unpacked left to right; the empty one adds nothing"
      },
      {
        "call": "flatten([])",
        "returns": "[]",
        "because": "no inner lists at all"
      }
    ],
    "terms": [
      {
        "term": "nested list",
        "meaning": "a list stored inside another list"
      }
    ]
  }
}
