{
  "id": "py-queue",
  "type": "python-kata",
  "track": "progression",
  "title": "Build a Queue",
  "xp": 45,
  "prerequisites": ["py-balanced-parens"],
  "review_interval_days": null,
  "prompt": "A queue is first-in, first-out — like a line at a counter. Implement a Queue class with enqueue(x) (join the back), dequeue() (removes and returns the front), peek() (returns the front without removing), is_empty(), and len() support (__len__).",
  "starter_code": "class Queue:\n    def __init__(self):\n        pass\n",
  "verification": {
    "runner": "python-script",
    "tests": [
      {
        "setup": ["q = Queue()", "q.enqueue(1)", "q.enqueue(2)", "q.enqueue(3)"],
        "checks": [
          { "call": "q.dequeue()", "expect": 1 },
          { "call": "q.peek()", "expect": 2 },
          { "call": "len(q)", "expect": 2 }
        ]
      },
      {
        "setup": ["q = Queue()"],
        "checks": [{ "call": "q.is_empty()", "expect": true }]
      },
      {
        "setup": ["q = Queue()", "q.enqueue('a')", "x = q.dequeue()", "q.enqueue('b')", "q.enqueue('c')"],
        "checks": [
          { "call": "x", "expect": "a" },
          { "call": "q.dequeue()", "expect": "b" },
          { "call": "q.dequeue()", "expect": "c" },
          { "call": "q.is_empty()", "expect": true }
        ]
      }
    ]
  }
}
