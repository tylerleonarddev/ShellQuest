  "review_interval_days": null,
  "prompt": "Write power(base, exp) computing base**exp for exp>=0, using recursion. power(x,0) is 1.",
  "starter_code": "def power(base, exp):\n    pass\n",
  "verification": {
    "runner": "python-test",
    "tests": [
      {
        "call": "power(2,10)",
        "expect": 1024
      },
      {
        "call": "power(5,0)",
        "expect": 1
      },
      {
        "call": "power(3,3)",
        "expect": 27
      },
      {
        "call": "power(7,1)",
        "expect": 7
      }
    ]
  },
  "details": {
    "restate": "Compute base raised to the power exp (exp is 0 or more), using recursion. Anything to the power 0 is 1.",
    "io": [
      {
        "call": "power(2, 10)",
        "returns": "1024",
        "because": "2 multiplied by itself 10 times"
      },
      {
        "call": "power(5, 0)",
        "returns": "1",
        "because": "the power-0 case is defined as 1 — it's also the recursion's stopping point"
      }
    ]
  }
